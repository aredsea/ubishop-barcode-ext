{
  "manifest_version": 3,
  "name": "유비샵 바코드 라벨 인쇄 (ActiveX 대체)",
  "version": "1.7.0",
  "description": "스윙브라우저/ActiveX 없이 일반 크롬에서 유비샵 주얼리 바코드 라벨을 인쇄한다. 옵션 위치설정·라이브 자동업데이트(GitHub). (Zebra GX430t / 60×10mm)",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "http://ubdstore.ubshop.biz/info/item/infoItemList.do*",
        "https://ubdstore.ubshop.biz/info/item/infoItemList.do*"
      ],
      "js": ["src/bridge.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "ISOLATED"
    },
    {
      "matches": [
        "http://ubdstore.ubshop.biz/info/item/infoItemList.do*",
        "https://ubdstore.ubshop.biz/info/item/infoItemList.do*"
      ],
      "js": [
        "vendor/JsBarcode.all.min.js",
        "src/font.js",
        "src/loader.js"
      ],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    }
  ]
}
